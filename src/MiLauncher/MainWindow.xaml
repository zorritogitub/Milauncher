<Window x:Class="MiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mi Súper Launcher" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E282C"
        Foreground="White"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        WindowState="Normal">
    
    <Window.Resources>
        <!-- Colores estilo Blizzard -->
        <SolidColorBrush x:Key="BackgroundDark" Color="#1E282C"/>
        <SolidColorBrush x:Key="BackgroundDarker" Color="#0F1719"/>
        <SolidColorBrush x:Key="BackgroundSidebar" Color="#162022"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#00AEFF"/>
        <SolidColorBrush x:Key="AccentBlueHover" Color="#4AC7FF"/>
        <SolidColorBrush x:Key="TextLight" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8A9BA3"/>
        
        <!-- Estilo para botones de la sidebar -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3A40"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Estilo para el botón de jugar -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Border principal para dar efecto de ventana personalizada -->
    <Border Background="{StaticResource BackgroundDark}" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/> <!-- Barra de título -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título personalizada -->
            <Grid Grid.Row="0" Background="{StaticResource BackgroundDarker}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="MI LAUNCHER" 
                           Grid.Column="0"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Content="─" 
                            Click="Minimize_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            Width="30"
                            FontSize="14"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="□" 
                            Click="Maximize_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            Width="30"
                            FontSize="12"
                            Cursor="Hand"/>
                    <Button Content="✕" 
                            Click="Close_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            Width="30"
                            FontSize="14"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Contenido principal -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/> <!-- Sidebar -->
                    <ColumnDefinition Width="*"/> <!-- Contenido principal -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar estilo Blizzard -->
                <Border Grid.Column="0" Background="{StaticResource BackgroundSidebar}">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo y perfil -->
                        <StackPanel Grid.Row="0" Margin="20,0">
                            <TextBlock Text="MI LAUNCHER" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,30"/>
                            
                            <Border Background="#2A3A40"
                                    CornerRadius="5"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Usuario" 
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                    <TextBlock Text="online" 
                                               Foreground="{StaticResource AccentBlue}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Botones de navegación -->
                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <Button Style="{StaticResource SidebarButtonStyle}" 
                                    Content="JUEGOS" 
                                    Click="Juegos_Click"/>
                            <Button Style="{StaticResource SidebarButtonStyle}" 
                                    Content="TIENDA" 
                                    Click="Tienda_Click"/>
                            <Button Style="{StaticResource SidebarButtonStyle}" 
                                    Content="NOTICIAS" 
                                    Click="Noticias_Click"/>
                        </StackPanel>

                        <!-- Configuración -->
                        <StackPanel Grid.Row="2" Margin="0,20">
                            <Button Style="{StaticResource SidebarButtonStyle}" 
                                    Content="CONFIGURACIÓN" 
                                    Click="Configuracion_Click"/>
                            <Button Style="{StaticResource SidebarButtonStyle}" 
                                    Content="SALIR" 
                                    Click="Salir_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Área de contenido principal -->
                <ScrollViewer Grid.Column="1" 
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BackgroundDark}">
                    <StackPanel Margin="30">
                        
                        <!-- Banner destacado -->
                        <Border Background="#2A3A40"
                                CornerRadius="10"
                                Height="200"
                                Margin="0,0,0,30">
                            <Grid>
                                <Image Source="https://via.placeholder.com/800x200/0F1719/00AEFF?text=JUEGO+DESTACADO"
                                       Stretch="UniformToFill"/>
                                <Border VerticalAlignment="Bottom"
                                        Background="#80000000"
                                        Padding="20">
                                    <TextBlock Text="JUEGO DESTACADO - YA DISPONIBLE"
                                               FontSize="24"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Sección: Tus juegos -->
                        <TextBlock Text="TUS JUEGOS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,15"/>

                        <!-- Grid de juegos -->
                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A3A40"
                                            CornerRadius="8"
                                            Width="200"
                                            Height="250"
                                            Margin="0,0,20,20"
                                            Cursor="Hand">
                                        <StackPanel>
                                            <Border Height="150"
                                                    Background="#162022"
                                                    CornerRadius="8,8,0,0">
                                                <TextBlock Text="🎮"
                                                           FontSize="50"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="15,10">
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding Estado}"
                                                           Foreground="{StaticResource AccentBlue}"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Noticias -->
                        <TextBlock Text="ÚLTIMAS NOTICIAS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,20,0,15"/>

                        <!-- Noticia 1 -->
                        <Border Background="#2A3A40"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="50"
                                        Height="50"
                                        Background="#162022"
                                        CornerRadius="5"
                                        Margin="0,0,15,0">
                                    <TextBlock Text="📰"
                                               FontSize="25"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Nueva actualización disponible"
                                               FontWeight="Bold"
                                               FontSize="16"/>
                                    <TextBlock Text="Hace 2 horas"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Noticia 2 -->
                        <Border Background="#2A3A40"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="50"
                                        Height="50"
                                        Background="#162022"
                                        CornerRadius="5"
                                        Margin="0,0,15,0">
                                    <TextBlock Text="🎁"
                                               FontSize="25"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Evento especial este fin de semana"
                                               FontWeight="Bold"
                                               FontSize="16"/>
                                    <TextBlock Text="Ayer"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Botón JUGAR flotante abajo a la derecha -->
                        <Border HorizontalAlignment="Right"
                                Margin="0,30,0,30">
                            <Button Style="{StaticResource PlayButtonStyle}"
                                    Content="JUGAR"
                                    Click="Jugar_Click"/>
                        </Border>

                        <!-- Barra de estado -->
                        <StatusBar Background="#162022"
                                   Margin="0,20,0,0">
                            <StatusBarItem>
                                <TextBlock x:Name="StatusText" 
                                           Text="Listo"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StatusBarItem>
                            <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock Text="v1.0.0"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StatusBarItem>
                        </StatusBar>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
