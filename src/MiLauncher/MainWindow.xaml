<Window x:Class="MiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mi Súper Launcher" 
        Height="400" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        Foreground="White">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Bienvenido a Mi Launcher" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Grid.Row="0"
                   Margin="0,0,0,20"/>

        <!-- Contenido principal -->
        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
            
            <TextBlock Text="Estado: Listo para jugar" 
                       FontSize="14"
                       Margin="0,0,0,10"/>
            
            <Button Content="JUGAR" 
                    Width="200" 
                    Height="50"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Jugar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Barra de estado - ¡AÑADIDO x:Name! -->
        <StatusBar Grid.Row="2" 
                   Background="#1A1A1A"
                   Margin="0,20,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="v1.0.0 - Listo"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
